# ══════════════════════════════════════════════════════════════════════════════
#  PYTHON
# ══════════════════════════════════════════════════════════════════════════════

# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
*.whl
sdist/

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# Pip
pip-log.txt
pip-delete-this-directory.txt


# ══════════════════════════════════════════════════════════════════════════════
#  TESTING & COVERAGE
# ══════════════════════════════════════════════════════════════════════════════

.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover
*.coveralls.json
junit*.xml
test-results/


# ══════════════════════════════════════════════════════════════════════════════
#  TYPE CHECKING & LINTING
# ══════════════════════════════════════════════════════════════════════════════

.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/


# ══════════════════════════════════════════════════════════════════════════════
#  IDE & EDITOR
# ══════════════════════════════════════════════════════════════════════════════

# VSCode
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
*~
.vim/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Codex / Cursor / AI tools
.codex
.cursorignore
.cursorindexingignore
.aider*
.continue/


# ══════════════════════════════════════════════════════════════════════════════
#  SECRETS & CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# Environment files  (giữ lại .env.example để làm template)
.env
.env.local
.env.*.local
!.env.example

# Certificates & keys
*.pem
*.key
*.crt
*.p12
*.pfx

# Local overrides
config.local.yml
secrets.yml
credentials.json


# ══════════════════════════════════════════════════════════════════════════════
#  RAW DATA (thường quá lớn để commit)
# ══════════════════════════════════════════════════════════════════════════════

data/facebook_data/batch_data/
data/facebook_data/stream_data/
data/facebook_data/raw_data/

data/instagram_data/batch_data/
data/instagram_data/stream_data/
data/instagram_data/raw_data/

data/reddit_data/batch_data/
data/reddit_data/stream_data/
data/reddit_data/raw_data/

# Giữ cấu trúc thư mục — dùng .gitkeep nếu cần
!data/**/.gitkeep


# ══════════════════════════════════════════════════════════════════════════════
#  SPARK
# ══════════════════════════════════════════════════════════════════════════════

# Checkpoint & streaming state
spark-checkpoints/
spark_checkpoints/
checkpoint/
checkpoints/
_spark_metadata/

# Spark local output (khi chạy local[*])
streaming-output/
streaming_output/
spark-warehouse/
metastore_db/
derby.log

# Ivy cache (JARs download bởi spark-submit --packages)
.ivy2/
ivy2/

# Parquet/Delta output
*.parquet
*.snappy.parquet
*.delta


# ══════════════════════════════════════════════════════════════════════════════
#  AIRFLOW
# ══════════════════════════════════════════════════════════════════════════════

# Airflow local DB (SQLite — chỉ dùng cho dev)
airflow.db
airflow.cfg

# Logs sinh ra bởi Airflow scheduler/worker
logs/
airflow/logs/

# Airflow compiled DAG cache
__pycache__/


# ══════════════════════════════════════════════════════════════════════════════
#  DOCKER
# ══════════════════════════════════════════════════════════════════════════════

# Docker override files (local tuning)
docker-compose.override.yml
docker-compose.local.yml

# Không ignore .dockerignore — nó cần được commit
# !.dockerignore


# ══════════════════════════════════════════════════════════════════════════════
#  NOTEBOOKS
# ══════════════════════════════════════════════════════════════════════════════

.ipynb_checkpoints/
*.ipynb


# ══════════════════════════════════════════════════════════════════════════════
#  LOGS & TEMP FILES
# ══════════════════════════════════════════════════════════════════════════════

*.log
*.log.*
*.tmp
*.temp
*.bak
*.swp
*.orig

# ETL state tracker (được mount qua Docker volume — không cần commit)
processed_dates.json


# ══════════════════════════════════════════════════════════════════════════════
#  JAVA / MAVEN (dependencies của Spark JARs)
# ══════════════════════════════════════════════════════════════════════════════

target/
*.class
*.jar
!spark/jars/          # nếu có thư mục jars custom — cần giữ lại
