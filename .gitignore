################################################################################
# IT4931 Data Pipeline - .gitignore
# Facebook, Reddit, Instagram Crawling & Kafka Pipeline
################################################################################

################################################################################
# PYTHON & ENVIRONMENT
################################################################################
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class
*.so
.Python
*.egg-info/
*.egg
MANIFEST
dist/
build/

# Virtual environments
venv/
.venv
env/
ENV/
*.venv

# Pip logs
pip-log.txt
pip-delete-this-directory.txt

################################################################################
# TESTING & COVERAGE
################################################################################
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml

################################################################################
# IDE & EDITOR
################################################################################
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.cursorignore

################################################################################
# DATA FILES & LOGS
################################################################################
# Crawled raw data (large, gitignore by default)
data/facebook_data/raw_data/
data/reddit_data/raw_data/
data/instagram_data/raw_data/

# Split data (generated by split_data_by_date.py scripts)
data_before_2026_04_10/
data_after_2026_04_10/
posts_before_2026_04_10.jsonl
posts_after_2026_04_10.jsonl

# Logs
*.log
logs/

# Temporary files
*.tmp
*.bak
*.temp

################################################################################
# CONFIGURATION & SECRETS
################################################################################
.env
.env.local
.env.*.local
.env.*.local.example
*.pem
*.key
config.local.yml

################################################################################
# DOCKER
################################################################################
.dockerignore

################################################################################
# NOTEBOOKS
################################################################################
.ipynb_checkpoints/
*.ipynb

################################################################################
# CACHE & MISC
################################################################################
.ruff_cache/
.mypy_cache/
.pytest_cache/
*.pyc
.DS_Store
data/reddit_data/reddit_all_topics.json
