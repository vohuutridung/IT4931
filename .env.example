# ── Môi trường ────────────────────────────────────────────────────────────────
ENV=dev

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Khi chạy local (ngoài Docker): localhost:9092
# Khi chạy trong Docker Compose: kafka:29092 (được set qua common-env)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Data paths ────────────────────────────────────────────────────────────────
# Thư mục gốc chứa data (optional — mặc định tự động resolve từ project root)
# DATA_DIR=/path/to/project/data

# Override từng platform nếu cần:
# FB_DATA_DIR=/path/to/facebook_data
# IG_DATA_DIR=/path/to/instagram_data
# REDDIT_DATA_DIR=/path/to/reddit_data

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_RAW=social-raw
MINIO_BUCKET_CLEAN=social-clean

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=social_db
MONGO_COLLECTION=posts_clean

# ── Kafka Consumer (batch-consumer) ──────────────────────────────────────────
KAFKA_CONSUMER_GROUP=batch-consumer-group
CONSUMER_FLUSH_SIZE=5000
CONSUMER_FLUSH_INTERVAL=120

# ── Spark ─────────────────────────────────────────────────────────────────────
# local[*] cho dev, spark://spark-master:7077 khi dùng cluster Docker
SPARK_MASTER=local[*]
SPARK_APP_NAME=SocialBatchETL
# S3A endpoint cho Spark ↔ MinIO (cần http://)
S3A_ENDPOINT=http://localhost:9000

# ── ETL Incremental Tracker ───────────────────────────────────────────────────
# Đường dẫn lưu trạng thái đã xử lý (cần nằm trên volume bền vững)
# ETL_TRACKER_FILE=/opt/etl_state/processed_dates.json
